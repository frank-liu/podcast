{
  "$id": "https://example.com/schemas/digest-event.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DigestEvent",
  "type": "object",
  "properties": {
    "digestId": {"type":"string"},
    "topicId": {"type":"string"},
    "publisherId": {"type":"string"},
    "language": {"type":"string","enum":["en","zh"]},
    "status": {"type":"string"},
    "audioUrl": {"type":"string"},
    "lengthSeconds": {"type":"integer"}
  },
  "required":["digestId","topicId","publisherId","language","status"]
}
